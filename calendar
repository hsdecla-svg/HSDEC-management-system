<!DOCTYPE html>
<html>
<head>
    <base target="_top">
    <style>
        body { font-family: 'Helvetica Neue', Arial, sans-serif; background: #f4f7f6; overflow-y: hidden; }
        .timeline-container {
            display: flex;
            align-items: flex-start;
            padding: 50px 20px;
            overflow-x: auto;
            height: 90vh;
            white-space: nowrap;
        }
        /* 年表の横線 */
        .timeline-container::before {
            content: '';
            position: absolute;
            top: 250px;
            left: 0;
            right: 0;
            height: 4px;
            background: #3498db;
            z-index: 0;
        }
        .event-card {
            display: inline-block;
            vertical-align: top;
            width: 300px;
            margin: 0 40px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            position: relative;
            z-index: 1;
            transition: transform 0.3s;
        }
        .event-card:hover { transform: translateY(-10px); }
        .event-image {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: 12px 12px 0 0;
            background: #eee;
        }
        .event-content { padding: 15px; white-space: normal; }
        .event-date { color: #3498db; font-weight: bold; font-size: 0.9em; margin-bottom: 5px; }
        .event-title { font-size: 1.1em; font-weight: bold; color: #2c3e50; }
        /* タイムラインの接点 */
        .dot {
            width: 20px;
            height: 20px;
            background: #3498db;
            border-radius: 50%;
            position: absolute;
            top: 190px; /* 線の上に配置 */
            left: 50%;
            transform: translateX(-50%);
            border: 4px solid white;
        }
    </style>
</head>
<body>
    <div class="timeline-container" id="timeline">
        </div>

    <script>
        function loadCalendar() {
            google.script.run.withSuccessHandler(displayEvents).getTimelineData();
        }

        function displayEvents(events) {
            const container = document.getElementById('timeline');
            events.forEach(event => {
                const card = document.createElement('div');
                card.className = 'event-card';
                
                // 画像リンクがあれば表示、なければプレースホルダー
                const imgSrc = event.photoUrl ? event.photoUrl : 'https://via.placeholder.com/300x180?text=No+Photo';
                
                card.innerHTML = `
                    <img src="${imgSrc}" class="event-image">
                    <div class="dot"></div>
                    <div class="event-content">
                        <div class="event-date">${event.date}</div>
                        <div class="event-title">${event.title}</div>
                    </div>
                `;
                container.appendChild(card);
            });
        }
        window.onload = loadCalendar;
    </script>
</body>
</html>
