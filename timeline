<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>HSDEC Global Hub</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/google-calendar@6.1.10/index.global.min.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
        body { background: #0f172a; font-family: 'Inter', sans-serif; color: white; overflow-x: hidden; }
        
        /* --- Timeline UI --- */
        .timeline-container {
            display: flex;
            overflow-x: auto;
            padding: 100px 50px;
            gap: 60px;
            position: relative;
            scrollbar-width: none;
            scroll-behavior: smooth;
        }
        .timeline-container::-webkit-scrollbar { display: none; }

        /* 青い中央線 */
        .timeline-line {
            position: absolute;
            top: 280px;
            left: 0;
            right: 0;
            height: 4px;
            background: #3498db;
            z-index: 0;
        }

        .event-card {
            min-width: 320px;
            background: white;
            border-radius: 16px;
            position: relative;
            z-index: 1;
            transition: all 0.3s ease;
            color: #1e293b;
            box-shadow: 0 15px 30px rgba(0,0,0,0.5);
            flex-shrink: 0;
        }
        .event-card:hover { transform: translateY(-15px); }

        .event-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 16px 16px 0 0;
            background: #cbd5e1;
        }

        .event-content { padding: 20px; }
        .event-date { color: #3498db; font-weight: 900; font-size: 0.85rem; margin-bottom: 4px; text-transform: uppercase; }
        .event-title { font-size: 1.25rem; font-weight: 900; line-height: 1.2; color: #0f172a; }

        /* タイムラインの接点（ドット） */
        .dot {
            width: 24px;
            height: 24px;
            background: #3498db;
            border-radius: 50%;
            position: absolute;
            bottom: -45px;
            left: 50%;
            transform: translateX(-50%);
            border: 5px solid #0f172a;
            box-shadow: 0 0 15px rgba(52, 152, 219, 0.5);
        }

        /* Menu Card UI */
        .menu-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }
        .menu-card:hover { border-color: #10b981; background: rgba(255, 255, 255, 0.07); }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center p-6">

    <div id="auth-section" class="w-full max-w-md space-y-8 mt-10">
        <div class="text-center">
            <h1 class="text-6xl font-black italic text-emerald-500 tracking-tighter">HSDEC</h1>
            <p class="text-slate-500 font-bold uppercase tracking-[0.4em] text-[10px] mt-2">Global Management Hub</p>
        </div>
        <div class="bg-white/5 p-8 rounded-[3rem] border border-white/10 shadow-2xl">
            <select id="user-select" class="w-full bg-slate-800 p-5 rounded-2xl mb-4 text-white font-black outline-none border-none appearance-none">
                <option value="Takashi">TAKASHI (Admin)</option>
                <option value="Chansouk">CHANSOUK (Staff)</option>
                <option value="Mim">MIM (Staff)</option>
                <option value="Guest">GUEST</option>
            </select>
            <input type="password" id="pass" placeholder="PASSWORD" class="w-full bg-slate-800 p-5 rounded-2xl mb-6 text-white text-center text-2xl font-black outline-none border-none">
            <button onclick="login()" class="w-full bg-emerald-500 hover:bg-emerald-400 text-white py-5 rounded-2xl font-black text-lg transition-all active:scale-95 shadow-lg shadow-emerald-500/20">ACCESS SYSTEM</button>
            <p id="error" class="text-rose-500 text-[10px] font-black mt-6 text-center hidden">INVALID CREDENTIALS</p>
        </div>
    </div>

    <div id="menu-section" class="hidden w-full max-w-6xl py-12">
        <div class="flex justify-between items-end px-6 mb-12">
            <div>
                <h2 class="text-5xl font-black italic tracking-tighter">DASHBOARD</h2>
                <p id="welcome-msg" class="text-emerald-500 font-black text-[10px] uppercase tracking-widest mt-2"></p>
            </div>
            <button onclick="location.reload()" class="px-8 py-3 bg-slate-800 rounded-full text-[10px] font-black uppercase hover:bg-slate-700 transition">Logout</button>
        </div>
        <div id="menu-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 px-6"></div>
    </div>

    <div id="timeline-section" class="hidden w-full min-h-screen">
        <div class="flex justify-between items-center px-10 pt-10">
            <h2 class="text-4xl font-black italic text-emerald-500 uppercase tracking-tighter">History Timeline</h2>
            <button onclick="backToMenu()" class="px-8 py-3 bg-white/10 rounded-full text-[10px] font-black uppercase hover:bg-white/20 transition">Back to Dashboard</button>
        </div>
        <div class="relative mt-20">
            <div class="timeline-line"></div>
            <div id="timeline-content" class="timeline-container">
                </div>
        </div>
    </div>

    <script>
        const CALENDAR_ID = 'hsdec.la@gmail.com';
        const API_KEY = 'AIzaSyCzE9RsYu1ec6_b0ePHj_7FEOh9aF0fQi0';

        const USER_DB = {
            "Takashi": { pw: "Tks83446412", role: "admin" },
            "Chansouk": { pw: "97372185", role: "staff" },
            "Mim": { pw: "78277996", role: "staff" },
            "Guest": { pw: "HSDEC2025", role: "guest" }
        };

        function login() {
            const user = document.getElementById('user-select').value;
            const pass = document.getElementById('pass').value;
            if (USER_DB[user] && USER_DB[user].pw === pass) {
                renderMenu(user, USER_DB[user].role);
            } else {
                document.getElementById('error').classList.remove('hidden');
                setTimeout(() => document.getElementById('error').classList.add('hidden'), 2000);
            }
        }

        function renderMenu(name, role) {
            document.getElementById('auth-section').classList.add('hidden');
            document.getElementById('menu-section').classList.remove('hidden');
            document.getElementById('welcome-msg').innerText = `IDENTIFIED AS: ${name} / ROLE: ${role.toUpperCase()}`;
            
            const grid = document.getElementById('menu-grid');
            grid.innerHTML = '';
            
            const menuData = [
                { title: 'Timeline', icon: '⏳', desc: 'Visual chronological schedule', action: 'openTimeline', roles: ['admin', 'staff', 'guest'] },
                { title: 'Workers', icon: '👤', desc: 'Manage labor database', url: 'worker.html', roles: ['admin', 'staff', 'guest'] },
                { title: 'Finance', icon: '💰', desc: 'Accounting and calculation', url: 'finance.html', roles: ['admin', 'staff'] },
                { title: 'Cloud', icon: '📸', desc: 'Google Drive access', url: 'https://drive.google.com/', roles: ['admin', 'staff'] }
            ];

            menuData.forEach(item => {
                if (item.roles.includes(role)) {
                    const card = document.createElement('div');
                    card.className = "menu-card p-10 rounded-[3rem] cursor-pointer group";
                    card.onclick = item.action ? () => window[item.action]() : () => location.href = item.url;
                    card.innerHTML = `
                        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">${item.icon}</div>
                        <h3 class="text-2xl font-black italic uppercase">${item.title}</h3>
                        <p class="text-slate-500 text-xs mt-3 font-bold">${item.desc}</p>
                    `;
                    grid.appendChild(card);
                }
            });
        }

        async function openTimeline() {
        document.getElementById('menu-section').classList.add('hidden');
        document.getElementById('timeline-section').classList.remove('hidden');
        
        const container = document.getElementById('timeline-content');
        container.innerHTML = '<div class="w-full text-center text-emerald-500 font-black animate-pulse uppercase tracking-widest">--- System Syncing ---</div>';

        try {
            const url = `https://www.googleapis.com/calendar/v3/calendars/${CALENDAR_ID}/events?key=${API_KEY}&singleEvents=true&orderBy=startTime&timeMin=2025-01-01T00:00:00Z`;
            const res = await fetch(url);
            const data = await res.json();
            
            container.innerHTML = ''; 

            if (!data.items || data.items.length === 0) {
                container.innerHTML = '<div class="text-slate-500 font-black">NO EVENTS FOUND</div>';
                return;
            }

            data.items.forEach(event => {
                const desc = event.description || '';
                const date = new Date(event.start.dateTime || event.start.date).toLocaleDateString('ja-JP', { month: 'short', day: 'numeric', weekday: 'short' });

                // --- 画像抽出ロジック ---
                let imageUrl = 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&q=80&w=400';
                let isGDrive = false;

                // 1. Google Driveリンクの抽出と変換
                const driveMatch = desc.match(/https:\/\/drive\.google\.com\/(?:file\/d\/|open\?id=)([a-zA-Z0-6_-]+)/);
                if (driveMatch) {
                    // サムネイル用URLに変換 (sz=w1000 で高画質化)
                    imageUrl = `https://drive.google.com/thumbnail?id=${driveMatch[1]}&sz=w1000`;
                    isGDrive = true;
                } 
                // 2. 直リンク画像 (jpg, png等) の抽出
                else {
                    const photoMatch = desc.match(/https?:\/\/[^\s]+(?:\.jpg|\.jpeg|\.png|\.webp)/i);
                    if (photoMatch) imageUrl = photoMatch[0];
                }

                const card = document.createElement('div');
                card.className = 'event-card';
                card.innerHTML = `
                    <div class="relative overflow-hidden rounded-t-2xl">
                        <img src="${imageUrl}" class="event-image" onerror="this.src='https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=400'">
                        ${isGDrive ? `
                            <div class="absolute bottom-3 left-3 bg-black/60 backdrop-blur-md px-3 py-1.5 rounded-full flex items-center gap-2 border border-white/20">
                                <span class="text-[10px] font-black text-white uppercase tracking-tighter">Google Drive</span>
                            </div>
                        ` : ''}
                    </div>
                    <div class="dot"></div>
                    <div class="event-content">
                        <div class="event-date">${date}</div>
                        <div class="event-title italic uppercase tracking-tighter">${event.summary || 'UNTITLED'}</div>
                        <div class="mt-4 pt-4 border-t border-slate-100">
                            <p class="text-[10px] text-slate-400 font-bold leading-relaxed line-clamp-3 uppercase">
                                ${desc.replace(/https?:\/\/[^\s]+/g, '').trim() || 'No additional records found in system archive.'}
                            </p>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });

        } catch (err) {
            container.innerHTML = '<div class="text-rose-500 font-black">CONNECTION ERROR</div>';
        }
    }

        function backToMenu() {
            document.getElementById('timeline-section').classList.add('hidden');
            document.getElementById('menu-section').classList.remove('hidden');
        }
    </script>
</body>
</html>
